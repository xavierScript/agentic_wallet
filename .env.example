# Solana RPC Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Wallet Encryption Passphrase (used to encrypt/decrypt private keys at rest)
# Must be at least 12 characters. All keypairs are AES-256-GCM encrypted with
# a key derived from this passphrase via PBKDF2 (210 000 iterations, SHA-512).
WALLET_PASSPHRASE=change-me-to-a-strong-passphrase

# Master Wallet — auto-funds newly created agent wallets.
# Base58-encoded secret key of your funding wallet. When set, every new agent
# wallet receives AGENT_SEED_SOL on creation (policy is attached BEFORE
# funding, so the agent is constrained from the first lamport).
# Leave blank to skip auto-funding (you can fund wallets manually later).
# ⚠️  For devnet/testnet only. On mainnet use a dedicated treasury wallet.
MASTER_WALLET_SECRET_KEY=your-base58-master-wallet-secret-key

# Amount of SOL to seed each new agent wallet (requires MASTER_WALLET_SECRET_KEY).
# Default: 0.05 SOL — enough for ~100 simple transfers on devnet.
AGENT_SEED_SOL=0.05

# Owner / operator wallet address (base58 Solana public key).
# When set, closing a wallet via the TUI will automatically sweep any
# remaining SOL balance to this address before deleting the keystore.
# Leave blank to skip the sweep (funds will be permanently inaccessible).
OWNER_ADDRESS=your-base58-owner-public-key

# ── Kora Gasless Relay ──────────────────────────────────────────────────
KORA_RPC_URL=http://localhost:8080
# KORA_API_KEY=your-api-key-here   # uncomment if kora.toml has [kora.auth] api_key set

# Kora signer private key (base58 or path to JSON keypair file)
# Generate with: solana-keygen new --outfile kora/kora-signer.json --no-bip39-passphrase
# Then paste the base58 key here, or use the file path
KORA_SIGNER_PRIVATE_KEY=your-base58-kora-signer-private-key

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info
